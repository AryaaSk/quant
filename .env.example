# Quant POC environment template. Copy to .env and fill in actual keys.

# LLM keys for agent-driven scraping (Phase 1 + Phase 2)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: Kalshi REST API credentials (only required if scraping Kalshi historical contracts).
# Public liquidity probing works without these.
KALSHI_EMAIL=
KALSHI_PASSWORD=

# Optional: FRED API key for macro time series. Free signup at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: The-Odds-API key for historical odds across many sports
THE_ODDS_API_KEY=

# Voyage AI embeddings (top-of-MTEB; paid API, ~$0.12-0.18 per 1M tokens)
# Used by TextBlockBuilder mode: voyage. Sign up: https://dash.voyageai.com/
VOYAGE_API_KEY=

# H200 deployment (defaults match Zoral; override if reusing for another box)
H200_HOST=35.230.182.229
H200_USER=theod
H200_KEY=~/.ssh/gcp_zoral_h200_ed25519
H200_GPU=6
H200_REMOTE_DIR=Aryaa/quant

# Pipeline behaviour
QUANT_TEXT_ENCODER=sentence-transformers/all-mpnet-base-v2
QUANT_DEFAULT_SEED=42
